    "@fastify/sensible": "^6.0.4",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.14.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "commander": "^14.0.0",
    "dotenv": "^17.0.0",
    "fastify": "^5.1.0",
    "node-cron": "^4.0.0",
